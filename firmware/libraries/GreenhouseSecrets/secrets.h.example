#pragma once
// ── GreenhouseSecrets: per-deployment WiFi/MQTT credentials ───────────────────
// Copy this file to "secrets.h" in this same folder and fill in your real
// values. secrets.h is gitignored (see .gitignore) -- it never gets
// committed, unlike the plaintext credentials this replaced (see
// IMPROVEMENTS.md finding A1). Every sketch that needs a credential
// #include <secrets.h> and only uses the #defines it actually needs; unused
// ones are harmless (same pattern as mesh_config.h's shared constants).

// ── Home WiFi ─────────────────────────────────────────────────────────────────
// Used by bridge_esp32 and cam_esp32 to actually join the network, and by
// both edge node sketches to scan for the router's channel (never join).
#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// ── Pi MQTT broker (bridge_esp32 only) ─────────────────────────────────────────
// Dedicated 'bridge' account (publish-only, sensor topics -- see
// pi/mosquitto/acl, IMPROVEMENTS.md finding A3), NOT the app's account.
// Value comes from device.json's bridge_username/bridge_password, written by
// pi/scripts/first_boot.sh.
#define MQTT_USER     "bridge"
#define MQTT_PASS     "your-mqtt-bridge-password"
