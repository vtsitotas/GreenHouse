                  padding: 16px; text-align: left; font-size: 13px; color: #555; }
          .step b { color: #2e7d32; }
        </style>
      </head>
      <body>
        <div class="card">
          <div class="spinner"></div>
          <h1>Connecting to WiFi…</h1>
          <p>Your greenhouse is connecting to <strong>{{ ssid }}</strong> and will restart in about 30 seconds.</p>
          <div class="step">
            <b>Next steps:</b><br>
            1. Reconnect your phone to your home WiFi<br>
            2. Open the <b>Greenhouse</b> app<br>
            3. Tap <b>"Find my greenhouse"</b>
          </div>
        </div>
      </body>
      </html>

runcmd:
  # ── Fix file ownership ────────────────────────────────────────────────────
  - chown -R pi:pi /home/pi/greenhouse

  # ── Run provision (sets up systemd; apt step is quick since pkgs cached) ──
  - bash /home/pi/greenhouse/scripts/provision.sh

  # ── Generate TLS certificates ─────────────────────────────────────────────
  - mkdir -p /home/pi/greenhouse/certs
  - openssl genrsa -out /home/pi/greenhouse/certs/ca.key 2048
  - openssl req -new -x509 -days 3650 -key /home/pi/greenhouse/certs/ca.key -out /home/pi/greenhouse/certs/ca.crt -subj "/CN=GreenhouseCA"
  - openssl genrsa -out /home/pi/greenhouse/certs/server.key 2048
  - openssl req -new -key /home/pi/greenhouse/certs/server.key -out /home/pi/greenhouse/certs/server.csr -subj "/CN=greenhouse.local"
  - openssl x509 -req -days 3650 -in /home/pi/greenhouse/certs/server.csr -CA /home/pi/greenhouse/certs/ca.crt -CAkey /home/pi/greenhouse/certs/ca.key -CAcreateserial -out /home/pi/greenhouse/certs/server.crt
  - chmod 600 /home/pi/greenhouse/certs/ca.key /home/pi/greenhouse/certs/server.key
  - chown -R pi:pi /home/pi/greenhouse/certs

  # ── Deploy Mosquitto config ───────────────────────────────────────────────
  - cp /home/pi/greenhouse/mosquitto/mosquitto.conf /etc/mosquitto/conf.d/greenhouse.conf
  - systemctl restart mosquitto

  # ── Signal completion: blink green LED 5× ────────────────────────────────
  - echo none > /sys/class/leds/ACT/trigger
  - for i in 1 2 3 4 5; do echo 1 > /sys/class/leds/ACT/brightness; sleep 0.4; echo 0 > /sys/class/leds/ACT/brightness; sleep 0.4; done
  - echo mmc0 > /sys/class/leds/ACT/trigger

  # ── Power off — Pi is ready to ship ──────────────────────────────────────
  - shutdown -h now
